@00000000
00500093   # addi  x1,x0,5        -> x1 = 5
00A00113   # addi  x2,x0,10       -> x2 = 10
002081B3   # add   x3,x1,x2       -> x3 = 15
40110233   # sub   x4,x2,x1       -> x4 = 5
00302023   # sw    x3,0(x0)       -> MEM[0] = 15
00002283   # lw    x5,0(x0)       -> x5 = 15
FE229CE3   # beq   x5,x2,-20      -> branch back if x5==x2 (not taken since 15≠10)
 
12345537   # lui   x10,0x12345    -> x10 = 0x12345000
00001617   # auipc x12,0x1        -> x12 = PC + 0x1000
008000EF   # jal   x1,8           -> jump forward (skip next instr)
06300313   # addi  x6,x0,99       -> skipped
03700313   # addi  x6,x0,55       -> executed after jump
02800113   # addi  x2,x0,40       -> x2 = 40
004100E7   # jalr  x1,4(x2)       -> PC = x2+4=44, skip next
04D00293   # addi  x5,x0,77       -> skipped due to jalr
